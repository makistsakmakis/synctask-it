# Entra ID app registration (SPA platform)
VITE_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000

# SharePoint location of the lists
VITE_SP_HOSTNAME=inventorac.sharepoint.com
VITE_SP_SITE_PATH=/sites/ProjectManagement/Development

# List display names (change if yours differ)
VITE_LIST_REQUESTS=Requests
VITE_LIST_MANAGERS=Managers
VITE_LIST_RESOURCES=Resources

# Comma-separated emails that get the Admin / COO role
VITE_ADMIN_EMAILS=you@inventor.ac
